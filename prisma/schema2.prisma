generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client2"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL_2")
}

model contacts {
  id            Int       @id @default(autoincrement())
  name          String
  email         String
  mobile        String
  business_type String
  website_name  String
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
}

model leads {
  id           Int       @id @default(autoincrement())
  name         String
  email        String
  website_url  String?
  website_name String    @default("site-indexer.com")
  created_at   DateTime? @default(now()) @db.Timestamptz(6)
  company      String?
}

model restaurant_contacts {
  id              Int       @id @default(autoincrement())
  name            String
  restaurant_name String
  phone           String
  email           String
  website_name    String
  created_at      DateTime? @default(now()) @db.Timestamptz(6)
}
