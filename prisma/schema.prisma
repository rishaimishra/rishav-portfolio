generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Project {
  id            String    @id @default(cuid())
  title         String
  slug          String    @unique
  description   String
  techStack     String[]
  image         String?
  liveUrl       String?
  githubUrl     String?
  featured      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Lead {
  id            String    @id @default(cuid())
  name          String
  email         String
  message       String
  createdAt     DateTime  @default(now())
}
