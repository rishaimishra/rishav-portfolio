generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client2"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL_2")
}

model Lead {
  id        String   @id
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}

model Project {
  id          String   @id
  title       String
  slug        String   @unique
  description String
  techStack   String[]
  image       String?
  liveUrl     String?
  githubUrl   String?
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime
}

model User {
  id        String   @id
  email     String?  @unique
  name      String?
  password  String?
  createdAt DateTime @default(now())
  updatedAt DateTime
}
